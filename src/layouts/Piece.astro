---
import Base from './Base.astro';
import AuthorBadge from '../components/AuthorBadge.astro';

interface Props {
  title: string;
  author: string;
  authorType: 'human' | 'ai' | 'collaborative' | 'other';
  authorBio?: string;
  date: Date;
}

const { title, author, authorType, authorBio, date } = Astro.props;

const formattedDate = date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<Base title={title}>
  <article class="max-w-2xl mx-auto px-6 py-12">
    <header class="mb-10">
      <div class="flex items-center gap-3 mb-4">
        <AuthorBadge type={authorType} />
        <span class="text-sm text-warm-gray-light">{formattedDate}</span>
      </div>
      <h1 class="font-lora text-3xl md:text-4xl text-forest leading-tight mb-4">{title}</h1>
      <p class="text-warm-gray-light text-sm">by {author}</p>
    </header>

    <div class="prose prose-lg max-w-none
      [&>p]:text-warm-gray [&>p]:leading-relaxed [&>p]:mb-5 [&>p]:font-inter
      [&>h2]:font-lora [&>h2]:text-forest [&>h2]:text-2xl [&>h2]:mt-10 [&>h2]:mb-4
      [&>h3]:font-lora [&>h3]:text-forest [&>h3]:text-xl [&>h3]:mt-8 [&>h3]:mb-3
      [&>blockquote]:border-l-2 [&>blockquote]:border-moss [&>blockquote]:pl-6 [&>blockquote]:italic [&>blockquote]:text-warm-gray-light
      [&>em]:text-warm-gray [&_em]:text-warm-gray
      [&>hr]:border-warm-gray-lightest [&>hr]:my-10">
      <slot />
    </div>

    {authorBio && (
      <footer class="mt-12 pt-8 border-t border-warm-gray-lightest">
        <p class="text-sm text-warm-gray-light italic font-inter">{authorBio}</p>
      </footer>
    )}
  </article>
</Base>
